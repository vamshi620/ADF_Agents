# ─────────────────────────────────────────────────────────────────────────────
#  ADF Copilot Agents – Environment Configuration
#  Copy this file to .env and fill in your actual values.
#  NEVER commit the actual .env file to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── SQL Server Connection ────────────────────────────────────────────────────
# Reference: C:\VAMSHI\E2Eagent (same DB as the E2E agent project)
DB_SERVER=localhost
DB_DATABASE=QNXT_PLANDATA_UNV

# Windows Authentication (Trusted Connection — matches E2E agent project)
DB_TRUSTED_CONNECTION=true

# Or SQL Auth (comment out TRUSTED_CONNECTION above and fill these in):
# DB_USER=sa
# DB_PASSWORD=YourStrongPassword!

DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true

# Optional: named instance port (leave blank for default 1433)
# DB_PORT=1433

# Optional: ODBC driver for Windows Auth (defaults to ODBC Driver 17)
# DB_ODBC_DRIVER=ODBC Driver 17 for SQL Server

# ── Azure Data Factory ───────────────────────────────────────────────────────
# Fill these in when you have an Azure subscription.
# The ADF deploy and run agents will warn you if these are placeholder values.

AZURE_SUBSCRIPTION_ID=<your-subscription-id>
AZURE_RESOURCE_GROUP=<your-resource-group-name>
AZURE_ADF_FACTORY_NAME=<your-adf-factory-name>
AZURE_REGION=eastus

# ── Azure Auth: Service Principal (for automated / CI deployments) ───────────
# Create a Service Principal:
#   az ad sp create-for-rbac --name "adf-copilot-agent" --role contributor \
#     --scopes /subscriptions/<subscriptionId>/resourceGroups/<resourceGroup>
AZURE_TENANT_ID=<your-tenant-id>
AZURE_CLIENT_ID=<your-service-principal-app-id>
AZURE_CLIENT_SECRET=<your-service-principal-secret>

# ── Azure Auth: Azure CLI (simpler — just run `az login` in your terminal) ───
# No credentials needed here — the deploy/run agents will call:
#   az account get-access-token --resource https://management.azure.com
# The agent will ask you which auth method to use at deploy time.

# ── Workspace / Output ───────────────────────────────────────────────────────
# ADF_MEMORY.md and generated SQL/ARM templates are stored here
# (relative to project root — do not change)
OUTPUT_DIR=./workspace
